# =============================================================================
#  OpenShare — configuration
#  Copy to .env and fill in. This local .env is the ONLY place secrets live;
#  it is gitignored and never uploaded.
#      cp .env.example .env
#  Generate a session secret with:  openssl rand -base64 48
# =============================================================================

# Signing key for session cookies (REQUIRED). Keep it secret; rotate to log everyone out.
SESSION_SECRET=CHANGE_ME_run_openssl_rand_base64_48

# ── Auth: OpenID Connect provider (Authentik, Keycloak, etc.) ────────────────
# Create an OAuth2/OpenID application for OpenShare and paste its credentials.
OIDC_CLIENT_ID=CHANGE_ME
OIDC_CLIENT_SECRET=CHANGE_ME
OIDC_ISSUER=https://auth.example.com/application/o/openshare/

# ── URLs ─────────────────────────────────────────────────────────────────────
# Public base URL where users reach OpenShare (used for OIDC redirect + share links).
PUBLIC_URL=https://share.example.com

# Cross-origin clients allowed to upload with credentials — e.g. your OpenChat URL.
# Comma-separated. Leave blank for same-origin only.
ALLOWED_ORIGINS=https://chat.example.com

# ── Storage ──────────────────────────────────────────────────────────────────
# Path INSIDE the container where files + thumbnails live (matches the compose mount).
STORAGE_ROOT=/srv/openshare

# Max archive size (MB) that OpenShare will expand for in-browser browsing.
ARCHIVE_MAX_MB=2048

# ── Deployment (read by docker-compose) ──────────────────────────────────────
# Host port to expose OpenShare on.
PORT=8800
# Host path that holds the uploaded files — point this at a big disk or NAS mount.
# Its container-side mount is STORAGE_ROOT above, so the two must be kept consistent.
STORAGE_PATH=./storage
# Host path for the SQLite metadata DB (small; keep on fast local disk).
DB_PATH=./data
